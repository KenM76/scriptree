{
  "schema_version": 1,
  "name": "SwDxfExport dxf_cleanup",
  "description": "Process a raw SolidWorks DXF into a plasma-ready profile: remove chamfer/fillet artifacts, filter tapped holes, and normalize units.",
  "executable": "C:/Windows/py.exe",
  "working_directory": "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Solidworks/SwDxfExport",
  "argument_template": [
    "-3.12",
    "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Solidworks/SwDxfExport/dxf_cleanup.py",
    "{input}",
    "{output}",
    "{tapped}",
    "--unit",
    "{unit}"
  ],
  "params": [
    {
      "id": "input",
      "label": "Raw DXF input",
      "description": "Raw DXF file exported from SolidWorks (usually ending in _raw.dxf).",
      "type": "path",
      "widget": "file_open",
      "required": true,
      "default": "",
      "file_filter": "DXF files (*.dxf);;All files (*)"
    },
    {
      "id": "output",
      "label": "Cleaned DXF output",
      "description": "Path where the plasma-ready DXF will be written.",
      "type": "path",
      "widget": "file_save",
      "required": true,
      "default": "",
      "file_filter": "DXF files (*.dxf);;All files (*)"
    },
    {
      "id": "tapped",
      "label": "Tapped-hole sidecar (optional)",
      "description": "Optional text file listing tapped hole positions + diameters written by dxf_export.csx. Leave blank if you're not filtering tapped holes.",
      "type": "path",
      "widget": "file_open",
      "required": false,
      "default": "",
      "file_filter": "Text files (*.txt);;All files (*)"
    },
    {
      "id": "unit",
      "label": "Document unit",
      "description": "SolidWorks swLengthUnit_e code of the source document. Controls tolerance and $INSUNITS in the output DXF.",
      "type": "enum",
      "widget": "dropdown",
      "required": true,
      "default": "3",
      "choices": [
        "0",
        "1",
        "2",
        "3",
        "4",
        "5"
      ],
      "choice_labels": [
        "",
        "",
        "",
        "3 in",
        "",
        ""
      ]
    }
  ],
  "source": {
    "mode": "manual",
    "help_text_cached": null
  }
}