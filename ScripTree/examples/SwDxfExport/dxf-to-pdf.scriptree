{
  "schema_version": 1,
  "name": "SwDxfExport dxf_to_pdf",
  "description": "Render every DXF in a directory into a single multi-page PDF (one DXF per page, scaled to fit an 11x17 sheet).",
  "executable": "C:/Windows/py.exe",
  "working_directory": "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Solidworks/SwDxfExport",
  "argument_template": [
    "-3.12",
    "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Solidworks/SwDxfExport/dxf_to_pdf.py",
    "{input_dir}",
    "{output_pdf}",
    "--sort",
    "{sort}"
  ],
  "params": [
    {
      "id": "input_dir",
      "label": "DXF input directory",
      "description": "Folder containing cleaned .dxf files to render.",
      "type": "path",
      "widget": "folder",
      "required": true,
      "default": ""
    },
    {
      "id": "output_pdf",
      "label": "Output PDF",
      "description": "Path where the combined multi-page PDF will be written.",
      "type": "path",
      "widget": "file_save",
      "required": true,
      "default": "all_plates.pdf",
      "file_filter": "PDF files (*.pdf);;All files (*)"
    },
    {
      "id": "sort",
      "label": "Sort order",
      "description": "How to order the DXFs across pages of the PDF.",
      "type": "enum",
      "widget": "dropdown",
      "required": true,
      "default": "alpha",
      "choices": ["alpha", "size"]
    }
  ],
  "source": { "mode": "manual", "help_text_cached": null }
}
