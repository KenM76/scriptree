{
  "schema_version": 1,
  "name": "SwDxfExport dxf_export (via sw_bridge)",
  "description": "Export plasma-ready DXFs from the active SolidWorks assembly. Substitutes the output directory and BOM configuration into dxf_export.csx, then runs it through sw_bridge.",
  "executable": "C:/Windows/py.exe",
  "working_directory": "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Software/ScripTree/examples/SwDxfExport",
  "argument_template": [
    "-3.12",
    "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Software/ScripTree/examples/SwDxfExport/run_dxf_export.py",
    "--output-dir",
    "{output_dir}",
    "--config",
    "{config}",
    "--timeout",
    "{timeout}",
    "{no_pdf?--no-pdf}",
    "{csx?--csx=}",
    "{sw_bridge?--sw-bridge=}"
  ],
  "params": [
    {
      "id": "output_dir",
      "label": "Output directory",
      "description": "Folder where DXFs and export_log.txt will be written. Created if missing.",
      "type": "path",
      "widget": "folder",
      "required": true,
      "default": ""
    },
    {
      "id": "config",
      "label": "BOM configuration",
      "description": "Name of the assembly configuration whose BOM should be used (e.g. KIT, Default).",
      "type": "string",
      "widget": "text",
      "required": true,
      "default": "KIT"
    },
    {
      "id": "timeout",
      "label": "Timeout (seconds)",
      "description": "Kill sw_bridge if it runs longer than this. Default 600s (10 minutes) matches LLM_INSTRUCTIONS.md.",
      "type": "integer",
      "widget": "number",
      "required": true,
      "default": 600
    },
    {
      "id": "no_pdf",
      "label": "Skip PDF generation",
      "description": "If checked, sets generatePdf = false in the temp .csx so only DXFs are produced (no all_plates.pdf).",
      "type": "bool",
      "widget": "checkbox",
      "required": false,
      "default": false
    },
    {
      "id": "csx",
      "label": "Custom .csx template (optional)",
      "description": "Override the dxf_export.csx template path. Leave blank to use the default SwDxfExport copy.",
      "type": "path",
      "widget": "file_open",
      "required": false,
      "default": "",
      "file_filter": "C# script (*.csx);;All files (*)"
    },
    {
      "id": "sw_bridge",
      "label": "Custom sw_bridge.exe (optional)",
      "description": "Override the sw_bridge executable path. Leave blank to use the default Release build.",
      "type": "path",
      "widget": "file_open",
      "required": false,
      "default": "",
      "file_filter": "Executables (*.exe);;All files (*)"
    }
  ],
  "source": { "mode": "manual", "help_text_cached": null }
}
