{
  "schema_version": 1,
  "name": "SwApiTrainingGen",
  "description": "Generate training data from SolidWorks API documentation via the Anthropic API.",
  "executable": "C:/Users/Ken/OneDrive/Kens_Projects/Claude/Solidworks/SwApiTrainingGen/bin/Release/net48/SwApiTrainingGen.exe",
  "working_directory": null,
  "argument_template": [
    "--docs",
    "{docs}",
    "--out",
    "{out}",
    "--key",
    "{key}",
    "--model",
    "{model}",
    "{limit?--limit=}",
    "{pairs?--pairs=}",
    "{resume?--resume}"
  ],
  "params": [
    {
      "id": "docs",
      "label": "Docs directory",
      "description": "Folder containing the SolidWorks API documentation to process.",
      "type": "path",
      "widget": "folder",
      "required": true,
      "default": ""
    },
    {
      "id": "out",
      "label": "Output directory",
      "description": "Folder where the generated training data files will be written.",
      "type": "path",
      "widget": "folder",
      "required": true,
      "default": ""
    },
    {
      "id": "key",
      "label": "Anthropic API key",
      "description": "API key for the Anthropic API (kept local — not transmitted anywhere else).",
      "type": "string",
      "widget": "text",
      "required": true,
      "default": ""
    },
    {
      "id": "model",
      "label": "Model",
      "description": "Which Claude model to use for generation.",
      "type": "enum",
      "widget": "dropdown",
      "required": true,
      "default": "claude-sonnet-4-6",
      "choices": [
        "claude-opus-4-6",
        "claude-sonnet-4-6",
        "claude-haiku-4-5-20251001"
      ]
    },
    {
      "id": "limit",
      "label": "Document limit",
      "description": "Maximum number of documents to process (blank for no limit).",
      "type": "integer",
      "widget": "number",
      "required": false,
      "default": ""
    },
    {
      "id": "pairs",
      "label": "Pairs per document",
      "description": "Number of Q/A pairs to generate per document (blank for default).",
      "type": "integer",
      "widget": "number",
      "required": false,
      "default": ""
    },
    {
      "id": "resume",
      "label": "Resume previous run",
      "description": "If checked, skip documents already present in the output directory.",
      "type": "bool",
      "widget": "checkbox",
      "required": false,
      "default": false
    }
  ],
  "source": { "mode": "manual", "help_text_cached": null }
}
