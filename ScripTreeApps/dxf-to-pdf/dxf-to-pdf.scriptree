{
  "schema_version": 2,
  "name": "DXF to PDF",
  "description": "Render every DXF file in a directory into a single multi-page PDF. Each DXF is scaled to fit on its own 11x17 sheet with a title block showing the part name, size, and scale.",
  "executable": "py",
  "working_directory": "C:\\Dev\\Claude\\Software\\ScripTreeApps\\dxf-to-pdf",
  "argument_template": [
    "-3.12",
    "dxf_to_pdf.py",
    "{input_dir}",
    "{output}",
    ["--sort", "{sort}"]
  ],
  "params": [
    {
      "id": "input_dir",
      "label": "Input directory",
      "description": "Folder containing the DXF files to render (one page per DXF)",
      "type": "path",
      "widget": "folder",
      "required": true,
      "default": ""
    },
    {
      "id": "output",
      "label": "Output PDF",
      "description": "Path to write the multi-page PDF file",
      "type": "path",
      "widget": "file_save",
      "required": true,
      "default": "",
      "file_filter": "PDF files (*.pdf);;All files (*)"
    },
    {
      "id": "sort",
      "label": "Page sort order",
      "description": "Order pages alphabetically by filename or by file size (largest first)",
      "type": "enum",
      "widget": "dropdown",
      "required": true,
      "default": "alpha",
      "choices": [
        ["alpha", "Alphabetical (by filename)"],
        ["size", "By file size (largest first)"]
      ]
    }
  ],
  "env": {},
  "path_prepend": [],
  "source": {
    "mode": "manual",
    "help_text_cached": null
  }
}
