{
  "schema_version": 2,
  "name": "DXF Export (SolidWorks)",
  "description": "End-to-end DXF export pipeline for plasma-cutting plate parts from a SolidWorks assembly. Opens the assembly, inserts a BOM using the given configuration, exports each PLATE/SHEET row as a DXF, then cleans them up and renders a summary PDF. The cleanup and PDF stages run by default; toggle them off with the checkboxes below.",
  "executable": "py",
  "working_directory": "C:\\Dev\\Claude\\Software\\ScripTreeApps\\dxf-export",
  "argument_template": [
    "-3.12",
    "dxf_export.py",
    "{assembly}",
    "{config}",
    "{output_dir}",
    "{bom_template?--bom-template=}",
    "{sw_bridge?--sw-bridge=}",
    "{skip_cleanup?--skip-cleanup}",
    "{skip_pdf?--skip-pdf}"
  ],
  "params": [
    {
      "id": "assembly",
      "label": "Assembly file",
      "description": "Path to the SolidWorks assembly file (.sldasm) to export DXFs from",
      "type": "path",
      "widget": "file_open",
      "required": true,
      "default": "",
      "file_filter": "SolidWorks assemblies (*.sldasm *.SLDASM);;All files (*)",
      "section": "Input"
    },
    {
      "id": "config",
      "label": "Configuration",
      "description": "Name of the assembly configuration to use when generating the BOM (e.g. DXFS, KIT)",
      "type": "string",
      "widget": "text",
      "required": true,
      "default": "Default",
      "section": "Input"
    },
    {
      "id": "output_dir",
      "label": "Output folder",
      "description": "Directory to write the DXF files into (created if missing)",
      "type": "path",
      "widget": "folder",
      "required": true,
      "default": "",
      "section": "Input"
    },
    {
      "id": "bom_template",
      "label": "BOM template",
      "description": "Path to the .sldbomtbt BOM template file. Leave blank to use the default Claude_to_dxf.sldbomtbt next to the script.",
      "type": "path",
      "widget": "file_open",
      "required": false,
      "default": "",
      "file_filter": "BOM templates (*.sldbomtbt);;All files (*)",
      "section": "Advanced"
    },
    {
      "id": "sw_bridge",
      "label": "sw_bridge.exe",
      "description": "Path to the sw_bridge.exe executable that bridges to SolidWorks. Leave blank to use the default install location.",
      "type": "path",
      "widget": "file_open",
      "required": false,
      "default": "",
      "file_filter": "Executables (*.exe);;All files (*)",
      "section": "Advanced"
    },
    {
      "id": "skip_cleanup",
      "label": "Skip cleanup stage",
      "description": "Skip the DXF cleanup stage. Raw DXFs will be left in the output folder unchanged.",
      "type": "bool",
      "widget": "checkbox",
      "required": false,
      "default": false,
      "section": "Pipeline stages"
    },
    {
      "id": "skip_pdf",
      "label": "Skip PDF stage",
      "description": "Skip the final PDF generation stage.",
      "type": "bool",
      "widget": "checkbox",
      "required": false,
      "default": false,
      "section": "Pipeline stages"
    }
  ],
  "source": {
    "mode": "manual",
    "help_text_cached": null
  },
  "sections": [
    {
      "name": "Input",
      "collapsed": false
    },
    {
      "name": "Pipeline stages",
      "collapsed": false
    },
    {
      "name": "Advanced",
      "collapsed": false
    }
  ]
}