{
  "schema_version": 2,
  "name": "DXF Cleanup",
  "description": "Clean up a raw SolidWorks DXF export into a plasma-ready profile. Removes chamfer/fillet projection artifacts, dangling entities, countersink circles, and (optionally) tapped holes. Writes an AutoCAD 2000 (R2000) DXF with AutoCAD LT 2004 compatibility.",
  "executable": "py",
  "working_directory": "C:\\Dev\\Claude\\Software\\ScripTreeApps\\dxf-cleanup",
  "argument_template": [
    "-3.12",
    "dxf_cleanup.py",
    "{input}",
    "{output}",
    "{tapped?--tapped-sidecar=}",
    ["--unit", "{unit}"]
  ],
  "params": [
    {
      "id": "input",
      "label": "Input DXF",
      "description": "Path to the raw DXF file to clean up",
      "type": "path",
      "widget": "file_open",
      "required": true,
      "default": "",
      "file_filter": "DXF files (*.dxf);;All files (*)"
    },
    {
      "id": "output",
      "label": "Output DXF",
      "description": "Path to write the cleaned DXF file",
      "type": "path",
      "widget": "file_save",
      "required": true,
      "default": "",
      "file_filter": "DXF files (*.dxf);;All files (*)"
    },
    {
      "id": "tapped",
      "label": "Tapped holes sidecar",
      "description": "Optional path to a tapped-holes sidecar file with u,v,diameter per line",
      "type": "path",
      "widget": "file_open",
      "required": false,
      "default": "",
      "file_filter": "Text files (*.txt);;All files (*)"
    },
    {
      "id": "unit",
      "label": "Document unit",
      "description": "SolidWorks length unit of the source model",
      "type": "enum",
      "widget": "dropdown",
      "required": true,
      "default": "3",
      "choices": [
        ["0", "Millimeters"],
        ["1", "Centimeters"],
        ["2", "Meters"],
        ["3", "Inches"],
        ["4", "Feet"],
        ["5", "Feet & inches"]
      ]
    }
  ],
  "env": {},
  "path_prepend": [],
  "source": {
    "mode": "manual",
    "help_text_cached": null
  }
}
